{
  "name": "interview-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Desktop teleprompter for live video-call interviews.",
  "author": "janis",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "smoke:auth": "tsx scripts/smoke-auth.ts",
    "smoke:extract": "tsx scripts/smoke-extract.ts",
    "smoke:realtime": "tsx scripts/smoke-realtime.ts",
    "smoke:classifier": "tsx scripts/smoke-classifier.ts",
    "smoke:answer": "tsx scripts/smoke-answer.ts",
    "dist:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "dist:mac": "tsx scripts/build-mac.ts",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "gpt-tokenizer": "^3.4.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "archiver": "^7.0.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
